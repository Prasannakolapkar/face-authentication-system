# ─── Fraud Detection System — Environment Variables ───────────────────────────
# Copy this file to .env and fill in the values.
# The project uses python-dotenv to load .env automatically.

# ── Firebase Configuration ────────────────────────────────────────────────────
# Set USE_FIREBASE=true to use Firebase Firestore as the database backend.
# Leave unset or set to false to use the local SQLite database (default).
USE_FIREBASE=true

# Path to your Firebase service account JSON key file.
# Download from: Firebase Console → Project Settings → Service Accounts → Generate New Private Key
FIREBASE_CREDENTIALS_PATH=serviceAccountKey.json

# ── Email Alert Configuration (existing) ─────────────────────────────────────
# (Already configured in the project — listed here for reference)
# SENDER_EMAIL=your-gmail@gmail.com
# SENDER_APP_PASSWORD=your-gmail-app-password
